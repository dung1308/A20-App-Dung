# Local Docker Compose example

VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
VITE_USE_MOCK=false

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
SECRET_KEY=change-this-local-dev-secret
ADMIN_SIGNUP_KEY=change-this-admin-signup-key
ENVIRONMENT=development
LOG_LEVEL=INFO

OPENAI_API_KEY=sk-replace-with-your-openai-key
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
PROMPT_VERSION=v2
USE_MOCK=False

POSTGRES_DB=vinuni_db
POSTGRES_USER=vinuni_user2
POSTGRES_PASSWORD=change-this-local-db-password
PGDATABASE=${POSTGRES_DB}
PGUSER=${POSTGRES_USER}
PGPASSWORD=${POSTGRES_PASSWORD}
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
HUMAN_WEBHOOK=http://localhost:9000/handoff

RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
DAILY_LLM_BUDGET=100

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=replace-with-instructor-key
AI_LOG_DIR=.ai-log

