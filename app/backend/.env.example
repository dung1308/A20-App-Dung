# OpenAI API Configuration
OPENAI_API_KEY=...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Database Configuration
# Format for PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///./vinuni_match.db
USE_MOCK=False

# Budget & Cost Control (USD per 1,000 tokens)
DAILY_LLM_BUDGET=100.00
GLOBAL_DAILY_BUDGET_USD=5.00
USER_DAILY_BUDGET_USD=0.50
LLM_INPUT_COST_PER_1K=0.00015
LLM_OUTPUT_COST_PER_1K=0.00060
MAX_SINGLE_PROMPT_TOKENS=2000

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Infrastructure & Webhooks
REDIS_URL=redis://localhost:6379/0
HUMAN_WEBHOOK=http://localhost:9000/handoff

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
ALLOW_PROMPT_DELETION=true
